@page "/chat"
@rendermode InteractiveServer
@inject ChatService ChatService

<PageTitle>Chat</PageTitle>
<h3> AI chat </h3>


<input @bind="userInput" placeholder="Type something..." />
<button @onclick="Send">Send</button>

@if (isLoading)
{
    <p>Thinking...</p>
}

@if (!string.IsNullOrWhiteSpace(response))
{
    <p><strong> AI:</strong> @response</p>
}

@code {
    private string userInput = "";
    private string response = "";
    private bool isLoading = false;

    private async Task Send()
    
    {
        Console.WriteLine("Send button clicked with input: " + userInput); // Debug log
        if (string.IsNullOrWhiteSpace(userInput))// prevent sending empty messages
        {
            response = "Please enter a message.";
            return;
        }

        isLoading = true;
        response = "Button clicked, packing  message..."; // show immediate feedback

        try
        {
            var result = await ChatService.SendMessage(userInput);// send message to the service
            response = result; // update response with the result from the service
            
        }
        catch(Exception ex)
        {
            response = "Error: " + ex.Message; // handle any errors 
        }
        finally
        {
            isLoading = false; // reset loading state
            StateHasChanged(); // update UI with the response
        }
        Console.WriteLine("Response received: " + response); // Debug log
    }
}